# ============================================================
# .env.example — Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.
# ============================================================

# ---------------------------------------------------------------
# MetaTrader 5 — 4-account configuration
# Accounts 1 & 2 trade BUY only; accounts 3 & 4 trade SELL only.
# ---------------------------------------------------------------
MT5_LOGIN_1=12345678          # Account 1 number (integer)
MT5_PASSWORD_1=your_password  # Account 1 password
MT5_SERVER_1=YourBroker-Live  # Account 1 server (e.g. ICMarkets-Live)
MT5_DIRECTION_1=BUY           # BUY or SELL

MT5_LOGIN_2=12345679
MT5_PASSWORD_2=your_password
MT5_SERVER_2=YourBroker-Live
MT5_DIRECTION_2=BUY

MT5_LOGIN_3=12345680
MT5_PASSWORD_3=your_password
MT5_SERVER_3=YourBroker-Live
MT5_DIRECTION_3=SELL

MT5_LOGIN_4=12345681
MT5_PASSWORD_4=your_password
MT5_SERVER_4=YourBroker-Live
MT5_DIRECTION_4=SELL

# Legacy single-account config (unused in 4-account mode, kept for tooling)
MT5_LOGIN=12345678
MT5_PASSWORD=your_password
MT5_SERVER=YourBroker-Live
# MT5_PATH=C:\path\to\terminal64.exe   # Optional: only needed if MT5 is not on PATH

# ---------------------------------------------------------------
# Symbol suffix (broker-specific, leave empty if not needed)
# ---------------------------------------------------------------
SYMBOL_SUFFIX=              # e.g. ".r" for raw accounts, "" for standard

# ---------------------------------------------------------------
# OpenAI / GPT-4o
# ---------------------------------------------------------------
OPENAI_API_KEY=sk-...       # Your OpenAI API key
OPENAI_MODEL=gpt-4o         # Model to use (default: gpt-4o)

# ---------------------------------------------------------------
# Execution mode
# ---------------------------------------------------------------
EXECUTION_LIVE=True         # Set to False for dry-run (no real orders placed)

# ---------------------------------------------------------------
# Database
# ---------------------------------------------------------------
DB_PATH=trading_bot.db      # SQLite file path (relative to project root)

# ---------------------------------------------------------------
# Tick polling interval
# ---------------------------------------------------------------
TICK_INTERVAL_SEC=2.0       # Seconds between price polls per instrument

# ---------------------------------------------------------------
# Per-trade size limits (4-account mode)
# ---------------------------------------------------------------
MAX_DAILY_TRADES=2          # Max executed trades per account per day
LOT_MIN=0.05                # Minimum lot size (clamp floor)
LOT_MAX=0.10                # Maximum lot size (clamp ceiling)
SL_USD=50                   # Fixed USD risk per trade (stop-loss size)
TP_USD=150                  # Fixed USD profit target per trade (take-profit size)

# ---------------------------------------------------------------
# Telegram notifications (optional — leave blank to disable)
# ---------------------------------------------------------------
TELEGRAM_BOT_TOKEN=         # Bot token from @BotFather (e.g. 123456:ABC-DEF...)
TELEGRAM_CHAT_ID=           # Chat or channel ID to send alerts to (e.g. -100123456789)
